{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-resource-read-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPDATA/plugins/**",
        "$RESOURCE/plugins/**",
        "$DOWNLOAD/**",
        "$DOCUMENT/**",
        "$DESKTOP/**",
        "$HOME/**"
      ]
    }
  ]
}
